# 最小环境变量占位。当前代码读取 API 入口、auth/session、CORS 和前端本地 API base 配置。
# 注意：本文件只允许占位符或明显 fake 值，不得写入真实密钥、真实密码、真实 token 或真实 DSN。
API_TITLE=ai-for-interviewer
API_VERSION=0.1.0
API_HOST=127.0.0.1
API_PORT=8001
API_PREFIX=/api/v1
API_AUTH_DEV_USER_ENABLED=true
API_AUTH_DEV_USER_IDENTIFIER=developer
API_AUTH_DEV_USER_EMAIL=developer@example.com
API_AUTH_DEV_USER_USERNAME=developer
API_AUTH_DEV_DISPLAY_NAME="F5 Dev User"
API_AUTH_DEV_USER_PASSWORD=change-me-local-only
API_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
VITE_API_BASE_URL=http://127.0.0.1:8001/api/v1

# Local PostgreSQL for docker-compose.pg.yml and SQLAlchemy/Alembic.
POSTGRES_DB=aifi_dev
POSTGRES_USER=aifi_dev
POSTGRES_PASSWORD=change-me-local-only
API_DATABASE_URL=postgresql+psycopg://aifi_dev:change-me-local-only@127.0.0.1:15432/aifi_dev

# LLM / OpenAI-compatible model config.
# 真实密钥只写入本地 .env，不要提交到仓库。
LLM_PROVIDER=openai_compatible
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o-mini
LLM_OPENAI_API_KEY=
LLM_OPENAI_TIMEOUT_SECONDS=90
LLM_OPENAI_TEMPERATURE=0

# Asset RAG embedding config.
# 真实密钥只写入本地 .env；EMBEDDING_PROVIDER 默认使用 OpenAI-compatible provider，测试用 fake provider 只能在测试内注入。
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
# 当前 RAG pgvector migration 使用 vector(1536) 并在该维度上创建 HNSW index。
EMBEDDING_DIMENSION=1536
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=45

# AI Runtime / Graph Agent gates.
# 默认关闭 Graph Agent；关闭时 Polish question 会 fallback 到 direct LLM generation path。
AIFI_AI_RUNTIME_ENABLED=false
AIFI_AI_RUNTIME_LANGGRAPH_ENABLED=false
AIFI_GRAPH_POLISH_QUESTION_ENABLED=false

# Graph provider gate.
# 仅控制 Graph Agent provider path；不控制 direct LLM path。
# 开启前必须保证 LLM_PROVIDER 不是 fake，且 LLM_OPENAI_API_KEY 已配置。
AIFI_REAL_PROVIDER_ENABLED=false

# Local raw LLM I/O dump.
# 仅本地调试使用。开启后会把 raw request/response 写入本地 JSON 文件。
# 不建议生产开启。
AIFI_LOCAL_LLM_RAW_IO_ENABLED=false
AIFI_LOCAL_LLM_RAW_IO_DIR=.local/llm-raw
AIFI_LOCAL_LLM_RAW_IO_INCLUDE_HEADERS=false

# Asset RAG embedding config
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_OPENAI_API_KEY=你的真实_key
EMBEDDING_TIMEOUT_SECONDS=45
