# 最小环境变量占位（示例值）
# 注意：仅为开发示例，不含真实密钥或真实 DSN。
ENVIRONMENT=development

# API lane
API_HOST=127.0.0.1
API_PORT=8001
API_PREFIX=/api/v1
# 优先级高于 API_DATABASE_PATH。留空时继续使用 SQLite fallback。
# 示例值只用于本地开发，不要写入真实生产账号或密码。
DATABASE_URL=
# 留空时 API 使用系统临时目录下的本地 sqlite 文件。
API_DATABASE_PATH=
# 仅用于手动启用 PostgreSQL integration tests，默认留空时 PG 测试会 skip。
TEST_DATABASE_URL=

# LLM provider lane
# openai 表示真实 provider 边界；deterministic 仅限 test/dev 显式配置。
# 真实 provider 缺少 key/model 时应失败，不会自动退回 deterministic。
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_BASE_URL=

# 外部依赖变量留空，仅作后续能力预留；不要写入真实 secret。
