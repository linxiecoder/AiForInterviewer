# 最小环境变量占位。当前代码读取 API 入口、auth/session、CORS 和前端本地 API base 配置。
# 注意：本文件只允许占位符或明显 fake 值，不得写入真实密钥、真实密码、真实 token 或真实 DSN。
API_TITLE=ai-for-interviewer
API_VERSION=0.1.0
API_HOST=127.0.0.1
API_PORT=8001
API_PREFIX=/api/v1
API_AUTH_DEV_USER_ENABLED=true
API_AUTH_DEV_USER_IDENTIFIER=developer
API_AUTH_DEV_USER_EMAIL=developer@example.com
API_AUTH_DEV_USER_USERNAME=developer
API_AUTH_DEV_DISPLAY_NAME="F5 Dev User"
API_AUTH_DEV_USER_PASSWORD=change-me-local-only
API_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
VITE_API_BASE_URL=http://127.0.0.1:8001/api/v1

# LLM / OpenAI-compatible model config.
# 真实密钥只写入本地 .env，不要提交到仓库。
LLM_PROVIDER=openai_compatible
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o-mini
LLM_OPENAI_API_KEY=
LLM_OPENAI_TIMEOUT_SECONDS=90
LLM_OPENAI_TEMPERATURE=0
