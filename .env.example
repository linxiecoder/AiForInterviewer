# 最小环境变量占位。
# 注意：本文件只允许占位符或明显 fake 值，不得写入真实密钥、真实密码、真实 token 或真实 DSN。
ENVIRONMENT=development

# API lane
API_HOST=127.0.0.1
API_PORT=8001
API_PREFIX=/api/v1
# 优先级高于 API_DATABASE_PATH。未配置时继续使用 SQLite fallback。
# 真实值只能写入本地 .env；格式示例见 docs/development/secrets-and-env.md。
DATABASE_URL=<postgresql_database_url_or_empty_for_sqlite>
# 未配置时 API 使用系统临时目录下的本地 sqlite 文件。
API_DATABASE_PATH=<local_sqlite_file_path_or_empty>
# 仅用于手动启用 PostgreSQL integration tests；未配置时 PG 测试会 skip。
TEST_DATABASE_URL=<postgresql_test_database_url_or_empty>

# PostgreSQL local compose lane
POSTGRES_USER=<postgres_user>
POSTGRES_PASSWORD=<postgres_password>
POSTGRES_DB=<postgres_database>

# LLM provider lane
# openai 表示真实 provider 边界；deterministic 仅限 test/dev 显式配置。
# 真实 provider 缺少 key/model 时应失败，不会自动退回 deterministic。
LLM_PROVIDER=<openai_or_deterministic_for_test_dev>
LLM_API_KEY=<your_llm_provider_api_key>
LLM_MODEL=<your_llm_model>
LLM_TIMEOUT_SECONDS=30
LLM_BASE_URL=<your_llm_provider_base_url_or_empty>

# 外部依赖变量留空，仅作后续能力预留；不要写入真实 secret。
